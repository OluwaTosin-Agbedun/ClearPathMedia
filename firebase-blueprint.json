    "adminAuditLog": {
      "title": "AdminAuditLog",
      "description": "System log tracking administrator security and content mutation actions.",
      "type": "object",
      "properties": {
        "adminEmail": { "type": "string" },
        "adminUid": { "type": "string" },
        "action": { "type": "string" },
        "targetEmail": { "type": "string" },
        "details": { "type": "object" },
        "timestamp": { "type": "string" }
      },
      "required": ["adminEmail", "adminUid", "action", "timestamp"]
    }
  },
  "firestore": {
    "users": { "schema": "user", "description": "Admin accounts." },
    "programmes": { "schema": "programme", "description": "The collection of ClearPath dynamic public programmes." },
    "programmeVideos": { "schema": "programmeVideo", "description": "The collection of videos under dynamic programmes." },
    "explainers": { "schema": "explainer", "description": "Dynamic explainers categories." },
    "explainerItems": { "schema": "explainerItem", "description": "Explainer articles and videos details." },
    "briefings": { "schema": "briefing", "description": "Dynamic briefings published." },
    "siteSettings": { "schema": "siteSettings", "description": "Global layout arrangements and values." },
    "partnerRequests": { "schema": "partnerRequest", "description": "Cooperation leads." },
    "newsletterSubscribers": { "schema": "newsletterSubscriber", "description": "Mailing list subscribers." },
    "contactMessages": { "schema": "contactMessage", "description": "Reach-out contact messages." },
    "adminAuditLogs": { "schema": "adminAuditLog", "description": "Administrator activity and security audit trail logs." }
  }
}
