        "isFeatured": { "type": "boolean" },
        "sortOrder": { "type": "integer" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "slug", "shortDescription", "status"]
    },
    "explainerItem": {
      "title": "ExplainerItem",
      "description": "A content post associated with an explainer.",
      "type": "object",
      "properties": {
        "explainerId": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "explainerType": { "type": "string", "enum": ["text", "video", "text-and-video"] },
        "youtubeUrl": { "type": "string" },
        "youtubeVideoId": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "featuredImage": { "type": "string" },
        "transcript": { "type": "string" },
        "keyQuestions": { "type": "string" },
        "keyPoints": { "type": "string" },
        "sourceLinks": { "type": "string" },
        "relatedDocuments": { "type": "array" },
        "topicTags": { "type": "array" },
        "coverageArea": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "isFeatured": { "type": "boolean" },
        "publishedAt": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" }
      },
      "required": ["explainerId", "title", "slug", "status"]
    },
    "briefing": {
      "title": "Briefing",
      "description": "A dynamic daily/weekly briefing entry.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "briefingType": { "type": "string", "enum": ["daily", "weekly", "special", "analysis"] },
        "presenter": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "youtubeVideoId": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "featuredImage": { "type": "string" },
        "keyPoints": { "type": "string" },
        "sourceLinks": { "type": "string" },
        "topicTags": { "type": "array" },
        "coverageArea": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "isFeatured": { "type": "boolean" },
        "publishedAt": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" }
      },
      "required": ["title", "slug", "status"]
    },
    "siteSettings": {
      "title": "SiteSettings",
      "description": "Site configurations and contact parameters.",
      "type": "object",
