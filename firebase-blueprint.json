{
  "entities": {
    "user": {
      "title": "User",
      "description": "An admin user who has access to the CMS dashboard.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth identifier." },
        "email": { "type": "string", "format": "email", "description": "The user's registered email address." },
        "name": { "type": "string", "description": "The custom name of the administrator." },
        "role": { "type": "string", "enum": ["super_admin", "admin", "content_admin", "viewer_admin"], "description": "The administrative access privilege level of the operator." },
        "createdAt": { "type": "string", "description": "Creation timestamp." }
      },
      "required": ["uid", "email", "role"]
    },
    "programme": {
      "title": "Programme",
      "description": "A structured media category published by ClearPath.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "tagline": { "type": "string" },
        "hostName": { "type": "string" },
        "formatType": { "type": "string", "enum": ["interview", "commentary", "daily-brief", "documentary", "panel", "analysis", "other"] },
        "coverageArea": { "type": "string", "enum": ["Nigeria", "Africa", "Global", "Nigeria & Africa", "other"] },
        "topicFocus": { "type": "array" },
        "scheduleText": { "type": "string" },
        "youtubePlaylistUrl": { "type": "string" },
        "coverImage": { "type": "string" },
        "thumbnailImage": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "isFeatured": { "type": "boolean" },
        "sortOrder": { "type": "integer" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "slug", "shortDescription", "status"]
    },
    "programmeVideo": {
      "title": "ProgrammeVideo",
      "description": "A dynamic video associated with a dynamic programme.",
      "type": "object",
      "properties": {
        "programmeId": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "shortSummary": { "type": "string" },
        "fullDescription": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "youtubeVideoId": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "duration": { "type": "string" },
        "presenters": { "type": "string" },
        "guests": { "type": "string" },
        "transcript": { "type": "string" },
        "keyPoints": { "type": "string" },
        "sourceLinks": { "type": "string" },
        "topicTags": { "type": "array" },
        "coverageArea": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "isFeatured": { "type": "boolean" },
        "publishedAt": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" }
      },
      "required": ["programmeId", "title", "slug", "youtubeVideoId", "status"]
    },
    "explainer": {
      "title": "Explainer",
      "description": "An evergreen dynamic explainer asset category.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "tagline": { "type": "string" },
        "coverageArea": { "type": "string", "enum": ["Nigeria", "Africa", "Global", "other"] },
        "topicFocus": { "type": "array" },
        "coverImage": { "type": "string" },
        "thumbnailImage": { "type": "string" },
