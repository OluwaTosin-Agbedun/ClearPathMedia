        "siteTagline": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroVideoUrl": { "type": "string" },
        "heroVideoId": { "type": "string" },
        "featuredProgrammeId": { "type": "string" },
        "featuredExplainerId": { "type": "string" },
        "featuredBriefingId": { "type": "string" },
        "youtubeChannelUrl": { "type": "string" },
        "facebookUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "xUrl": { "type": "string" },
        "tiktokUrl": { "type": "string" },
        "contactEmail": { "type": "string" },
        "partnershipEmail": { "type": "string" },
        "newsletterTitle": { "type": "string" },
        "newsletterDescription": { "type": "string" },
        "footerText": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["heroVideoId"]
    },
    "partnerRequest": {
      "title": "PartnerRequest",
      "description": "Institution partnership requests supporting legacy and new field maps.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "name": { "type": "string" },
        "organisation": { "type": "string" },
        "organization": { "type": "string" },
        "workEmail": { "type": "string", "format": "email" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "partnershipInterest": { "type": "string" },
        "partnershipType": { "type": "string" },
        "jobTitle": { "type": "string" },
        "role": { "type": "string" },
        "additionalInformation": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "submittedAt": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "newsletterSubscriber": {
      "title": "NewsletterSubscriber",
      "description": "Newsletter mailing registrations.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "selectedBriefings": { "type": "array" },
        "phone": { "type": "string" },
        "fullName": { "type": "string" },
        "interestArea": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "unsubscribed"] },
        "subscribedAt": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email"]
    },
    "contactMessage": {
      "title": "ContactMessage",
      "description": "Direct inquiries from reach out form.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
