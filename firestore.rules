rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Authentication Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to fetch user data if it exists
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ?
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data :
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
    }

    // Check if the user document exists in the database
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) || (
        request.auth != null && 
        request.auth.token != null && 
        'email' in request.auth.token && 
        exists(/databases/$(database)/documents/users/$(request.auth.token.email))
      );
    }

    // Is the user jerryagbedun@gmail.com (Implicit Super Admin)
    function isHardcodedSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "jerryagbedun@gmail.com";
    }

    // Is the user a registered active administrator?
    function isActiveAdmin() {
      return isHardcodedSuperAdmin() || (
        isSignedIn() && 
        userExists() && 
        getUserData().get('status', 'active') != "disabled" && 
        getUserData().get('disabled', false) != true
      );
    }

    // Is the user a Super Admin?
    function isSuperAdmin() {
      return isHardcodedSuperAdmin() || (
        isSignedIn() &&
        userExists() &&
        isActiveAdmin() &&
        (getUserData().get('role', 'viewer') == "super_admin" || getUserData().get('role', 'viewer') == "admin")
      );
    }

    // Is the user a Content Editor or Super Admin?
    function isEditorOrSuperAdmin() {
      return isHardcodedSuperAdmin() || (
        isSignedIn() &&
        userExists() &&
        isActiveAdmin() &&
        (
          getUserData().get('role', 'viewer') == "super_admin" || 
          getUserData().get('role', 'viewer') == "admin" || 
          getUserData().get('role', 'viewer') == "content_admin" ||
          getUserData().get('role', 'viewer') == "editor"
        )
      );
    }

    // --- Collections Configurations ---

    // 1. Users / Administrator Registry
    match /users/{userId} {
      allow read: if isSignedIn() && (
        userId == request.auth.uid || 
        (resource != null && 'email' in resource.data && resource.data.email == request.auth.token.email) ||
        isHardcodedSuperAdmin() ||
        isActiveAdmin()
      );
      allow write: if isSuperAdmin() || isHardcodedSuperAdmin();
      allow create, update: if isSignedIn() && (
        // The user is writing their own user record
        (
          userId == request.auth.uid || 
          userId == request.auth.token.email || 
          userId == request.auth.token.email.replace("@", "_").replace(".", "_") ||
          (request.auth.token.email == "jerryagbedun@gmail.com" && userId == "jerryagbedun_gmail_com")
        ) && 
        request.resource.data.email == request.auth.token.email
      ) && (
        // Safeguard: ordinary users cannot make themselves super_admins
        (resource == null && request.resource.data.get('role', 'viewer') != 'super_admin') ||
        // If it already exists, don't allow changing role or status except by super admin
        (resource != null && (
          request.resource.data.role == resource.data.role &&
          request.resource.data.status == resource.data.status
        ))
      );
    }

    // 2. Programmes Collection
    match /programmes/{docId} {
      allow read: if true;
      allow write: if isEditorOrSuperAdmin();
    }

    // 3. ProgrammeVideos Collection
    match /programmeVideos/{docId} {
      allow read: if true;
      allow write: if isEditorOrSuperAdmin();
    }

    // 4. Explainers Collection
    match /explainers/{docId} {
      allow read: if true;
      allow write: if isEditorOrSuperAdmin();
    }

    // 5. ExplainerItems Collection
    match /explainerItems/{docId} {
      allow read: if true;
      allow write: if isEditorOrSuperAdmin();
    }

    // 6. Briefings Collection
    match /briefings/{docId} {
      allow read: if true;
      allow write: if isEditorOrSuperAdmin();
    }

    // 7. SiteSettings Collection
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 8. PartnerRequests Collection (Corporate submissions)
    match /partnerRequests/{docId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin() || isEditorOrSuperAdmin(); // Editors can view leads, but viewer role is read-only
    }

    // 9. NewsletterSubscribers Collection
    match /newsletterSubscribers/{docId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin() || isEditorOrSuperAdmin();
    }

    // 10. ContactMessages Collection
    match /contactMessages/{docId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin() || isEditorOrSuperAdmin();
    }

    // 11. AdminAuditLogs Collection
    match /adminAuditLogs/{docId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }
  }
}
